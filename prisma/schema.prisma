// ============================================================================
// OnlyHalos Platform - Prisma Schema
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DEACTIVATED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum PostVisibility {
  PUBLIC
  SUBSCRIBERS
  TIER
  PPV
}

enum MediaType {
  IMAGE
  VIDEO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
}

enum TransactionType {
  SUBSCRIPTION
  TIP
  PPV_PURCHASE
  PAYOUT
  REFUND
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  NEW_SUBSCRIBER
  NEW_TIP
  NEW_MESSAGE
  NEW_COMMENT
  NEW_LIKE
  POST_PURCHASED
  SUBSCRIPTION_EXPIRED
  PAYOUT_COMPLETED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  SYSTEM
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE_CONTENT
  UNDERAGE
  IMPERSONATION
  COPYRIGHT
  OTHER
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================================================
// NEXTAUTH MODELS
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// CORE USER MODEL
// ============================================================================

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  emailVerified            DateTime?
  hashedPassword           String?
  username                 String?            @unique
  displayName              String?
  bio                      String?            @db.Text
  avatarUrl                String?
  coverUrl                 String?
  role                     UserRole           @default(USER)
  status                   AccountStatus      @default(ACTIVE)
  verificationStatus       VerificationStatus @default(UNVERIFIED)
  isCreator                Boolean            @default(false)
  creatorBio               String?            @db.Text
  location                 String?
  websiteUrl               String?
  twitterUrl               String?
  instagramUrl             String?
  tiktokUrl                String?
  stripeCustomerId         String?            @unique
  stripeConnectAccountId   String?            @unique
  stripeConnectOnboarded   Boolean            @default(false)
  platformFeePercent       Float?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Creator relations
  subscriptionTiers SubscriptionTier[]
  posts             Post[]
  payouts           Payout[]

  // Subscription relations (as subscriber)
  subscriptionsAsSubscriber Subscription[] @relation("SubscriptionSubscriber")
  // Subscription relations (as creator)
  subscriptionsAsCreator    Subscription[] @relation("SubscriptionCreator")

  // Engagement relations
  likes     Like[]
  comments  Comment[]
  bookmarks Bookmark[]

  // PPV purchases
  ppvPurchases PPVPurchase[]

  // Conversation relations
  conversationsAsUser1 Conversation[] @relation("ConversationUser1")
  conversationsAsUser2 Conversation[] @relation("ConversationUser2")

  // Message relations
  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")

  // Transaction relations
  sentTransactions     Transaction[] @relation("TransactionSender")
  receivedTransactions Transaction[] @relation("TransactionReceiver")

  // Notification relations
  notifications Notification[]

  // Report relations
  reportsFiled    Report[] @relation("ReportReporter")
  reportsAgainst  Report[] @relation("ReportedUser")
  reportsResolved Report[] @relation("ReportResolver")

  // Category relations
  creatorCategories CreatorCategory[]

  @@index([role])
  @@index([status])
  @@index([isCreator])
  @@index([verificationStatus])
  @@index([createdAt])
}

// ============================================================================
// SUBSCRIPTION & TIER MODELS
// ============================================================================

model SubscriptionTier {
  id              String   @id @default(cuid())
  creatorId       String
  name            String
  description     String?  @db.Text
  price           Float
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  features        String[]
  stripePriceId   String?  @unique
  stripeProductId String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator       User           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  posts         Post[]         @relation("PostMinimumTier")

  @@index([creatorId])
  @@index([isActive])
  @@index([stripePriceId])
}

model Subscription {
  id                   String             @id @default(cuid())
  subscriberId         String
  creatorId            String
  tierId               String
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  subscriber User             @relation("SubscriptionSubscriber", fields: [subscriberId], references: [id], onDelete: Cascade)
  creator    User             @relation("SubscriptionCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  tier       SubscriptionTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, creatorId])
  @@index([subscriberId])
  @@index([creatorId])
  @@index([tierId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([stripeSubscriptionId])
}

// ============================================================================
// POST & MEDIA MODELS
// ============================================================================

model Post {
  id            String         @id @default(cuid())
  creatorId     String
  caption       String?        @db.Text
  visibility    PostVisibility @default(SUBSCRIBERS)
  minimumTierId String?
  ppvPrice      Float?
  scheduledAt   DateTime?
  isPublished   Boolean        @default(true)
  likeCount     Int            @default(0)
  commentCount  Int            @default(0)
  bookmarkCount Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  creator      User              @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  minimumTier  SubscriptionTier? @relation("PostMinimumTier", fields: [minimumTierId], references: [id], onDelete: SetNull)
  media        PostMedia[]
  likes        Like[]
  comments     Comment[]
  bookmarks    Bookmark[]
  ppvPurchases PPVPurchase[]
  reports      Report[]

  @@index([creatorId])
  @@index([visibility])
  @@index([minimumTierId])
  @@index([isPublished])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([creatorId, isPublished, createdAt])
}

model PostMedia {
  id           String    @id @default(cuid())
  postId       String
  type         MediaType
  url          String
  thumbnailUrl String?
  width        Int?
  height       Int?
  duration     Float?
  size         Int?
  mimeType     String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([type])
}

// ============================================================================
// ENGAGEMENT MODELS
// ============================================================================

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String   @db.Text
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies Comment[] @relation("CommentReplies")

  @@index([userId])
  @@index([postId])
  @@index([parentId])
  @@index([createdAt])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([createdAt])
}

// ============================================================================
// PPV PURCHASE MODEL
// ============================================================================

model PPVPurchase {
  id                    String   @id @default(cuid())
  userId                String
  postId                String
  amount                Float
  stripePaymentIntentId String   @unique
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([stripePaymentIntentId])
}

// ============================================================================
// MESSAGING MODELS
// ============================================================================

model Conversation {
  id            String   @id @default(cuid())
  user1Id       String
  user2Id       String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user1    User      @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String
  content        String?  @db.Text
  mediaUrl       String?
  mediaType      String?
  isRead         Boolean  @default(false)
  ppvPrice       Float?
  isPurchased    Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User         @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([isRead])
  @@index([createdAt])
  @@index([conversationId, createdAt])
}

// ============================================================================
// TRANSACTION & PAYOUT MODELS
// ============================================================================

model Transaction {
  id                    String            @id @default(cuid())
  senderId              String?
  receiverId            String
  type                  TransactionType
  status                TransactionStatus @default(PENDING)
  amount                Float
  platformFee           Float
  netAmount             Float
  stripePaymentIntentId String?           @unique
  stripeTransferId      String?
  description           String?
  metadata              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  sender   User? @relation("TransactionSender", fields: [senderId], references: [id], onDelete: SetNull)
  receiver User  @relation("TransactionReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([type])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([createdAt])
  @@index([receiverId, type, createdAt])
}

model Payout {
  id             String       @id @default(cuid())
  creatorId      String
  amount         Float
  status         PayoutStatus @default(PENDING)
  currency       String       @default("usd")
  stripePayoutId String?      @unique
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([status])
  @@index([stripePayoutId])
  @@index([createdAt])
}

// ============================================================================
// NOTIFICATION MODEL
// ============================================================================

model Notification {
  id         String           @id @default(cuid())
  receiverId String
  type       NotificationType
  title      String
  body       String
  isRead     Boolean          @default(false)
  linkUrl    String?
  metadata   Json?
  createdAt  DateTime         @default(now())

  receiver User @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId])
  @@index([receiverId, isRead])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

// ============================================================================
// REPORT MODEL
// ============================================================================

model Report {
  id             String       @id @default(cuid())
  reporterId     String
  reportedUserId String?
  reportedPostId String?
  reason         ReportReason
  description    String?      @db.Text
  status         ReportStatus @default(PENDING)
  adminNote      String?      @db.Text
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reporter     User  @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User? @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reportedPost Post? @relation(fields: [reportedPostId], references: [id], onDelete: SetNull)
  resolvedBy   User? @relation("ReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([reportedPostId])
  @@index([status])
  @@index([reason])
  @@index([resolvedById])
  @@index([createdAt])
}

// ============================================================================
// CATEGORY MODELS
// ============================================================================

model Category {
  id        String @id @default(cuid())
  name      String @unique
  slug      String @unique
  iconUrl   String?
  sortOrder Int    @default(0)

  creatorCategories CreatorCategory[]

  @@index([slug])
  @@index([sortOrder])
}

model CreatorCategory {
  id         String @id @default(cuid())
  userId     String
  categoryId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
  @@index([categoryId])
}
